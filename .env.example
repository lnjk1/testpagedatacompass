# Data Compass API server configuration
# Copy this file to .env and fill in your values

# Secret key that the warehouse GitHub Actions pipeline must send in the X-API-Key header.
# Leave empty to disable auth (local development only).
WEBHOOK_API_KEY=changeme

# Port the Express API server listens on (default: 3001)
PORT=3001

# Set to "production" to also serve the React build from dist/
# NODE_ENV=production
