# Data Compass configuration
# Copy this file to .env and fill in your values

# URL of definitions.json in the warehouse repo (raw GitHub content URL).
# When set, the webapp fetches definitions from this URL instead of localStorage.
# Example: https://raw.githubusercontent.com/your-org/your-warehouse-repo/main/definitions.json
VITE_DEFINITIONS_URL=

# Base path for the app when deployed to a subdirectory (e.g. GitHub Pages).
# Set to /data-compass/ when deploying to https://your-org.github.io/data-compass/
# Leave empty for root deployments.
VITE_BASE=

# --- Express API server (legacy server-based approach, not needed for GitHub Pages) ---
# WEBHOOK_API_KEY=changeme
# PORT=3001
# NODE_ENV=production
